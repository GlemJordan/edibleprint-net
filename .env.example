# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXXX

# Google Places API (autocomplete)
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=

# Stripe
# Set STRIPE_MODE=test to use test keys, or STRIPE_MODE=live for production.
STRIPE_MODE=test

# Test keys (from Stripe Dashboard → Developers → API keys, toggle Test mode ON)
STRIPE_SECRET_KEY_TEST=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_...
STRIPE_WEBHOOK_SECRET_TEST=whsec_...

# Live keys (from Stripe Dashboard → Developers → API keys, toggle Test mode OFF)
# IMPORTANT: STRIPE_SECRET_KEY_LIVE must be a Secret Key (sk_live_...).
# A Restricted Key (rk_live_...) does NOT have permission to create Checkout Sessions.
# TODO(critical): replace the rk_live_... value in Vercel with a proper sk_live_... key.
STRIPE_SECRET_KEY_LIVE=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Deprecated — kept for backwards compatibility. Prefer the _TEST / _LIVE variants above.
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cloudinary (signed uploads for order files)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Admin API
ADMIN_API_TOKEN=

# Site
NEXT_PUBLIC_SITE_URL=https://edibleprint.net

# Email (Resend)
RESEND_API_KEY=
ORDER_NOTIFICATION_EMAIL=
